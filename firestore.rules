rules_version = '2';

// ════════════════════════════════════════════════════════════════
// CivilOS Ecosystem — Unified Firestore Security Rules
// Single Firebase project shared by:
//   1. CivilOS Hub             (projects, users, activity_logs, ...)
//   2. CivilOS Structural       (projects/{id} full design doc)
//   3. CivilOS Architectural    (drawings, projects/{id}/* bridge data)
//   4. CivilOS Estimating       (uses ecosystem bridge)
//   5. CivilOS Project Mgmt     (activities, tasks, issues, ...)
//   6. CivilOS Report & Export  (reports, templates, packages, ...)
//
// Model: any signed-in account (your team's Firebase Auth users)
// has full read/write access to the shared workspace. Anonymous /
// unauthenticated access is always denied.
// ════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ──────────────────────────────────────────────────────────
    // USERS — CivilOS Hub profile (uid, email, displayName, role)
    // Anyone signed in can read team profiles, but a user can
    // only create/update/delete their OWN profile document.
    // ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────────────────
    // PROJECTS — shared master record used by every app.
    // The wildcard below covers ALL nested subcollections that
    // the apps read/write for cross-app sync, e.g.:
    //   activity_logs, site_information, bnbc_settings,
    //   building_information, documents, structuralInput,
    //   estimatingInput, architecturalStatus, architecturalSummary,
    //   structuralGrid, schedules, bnbcReport, boq/{floorId}, etc.
    // ──────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read, write: if isSignedIn();

      match /{document=**} {
        allow read, write: if isSignedIn();
      }
    }

    // ──────────────────────────────────────────────────────────
    // DRAWINGS — CivilOS Architectural canvas data
    //   drawings/{projectId}/floors/{floorId}
    //   drawings/{projectId}/structuralGrid/data
    // ──────────────────────────────────────────────────────────
    match /drawings/{projectId} {
      allow read, write: if isSignedIn();

      match /{document=**} {
        allow read, write: if isSignedIn();
      }
    }

    // ──────────────────────────────────────────────────────────
    // REPORT & EXPORT app
    // ──────────────────────────────────────────────────────────
    match /reports/{reportId}           { allow read, write: if isSignedIn(); }
    match /reportTemplates/{templateId} { allow read, write: if isSignedIn(); }
    match /documentPackages/{packageId} { allow read, write: if isSignedIn(); }
    match /revisions/{revisionId}       { allow read, write: if isSignedIn(); }
    match /exports/{exportId}           { allow read, write: if isSignedIn(); }

    // Ecosystem bridge: civilos_bridge/{projectId}_{sourceApp}
    match /civilos_bridge/{bridgeDocId} { allow read, write: if isSignedIn(); }

    // ──────────────────────────────────────────────────────────
    // PROJECT MANAGEMENT app
    // ──────────────────────────────────────────────────────────
    match /activities/{id}        { allow read, write: if isSignedIn(); }
    match /tasks/{id}              { allow read, write: if isSignedIn(); }
    match /procurement/{id}        { allow read, write: if isSignedIn(); }
    match /handover_items/{id}     { allow read, write: if isSignedIn(); }
    match /punch_list/{id}         { allow read, write: if isSignedIn(); }
    match /final_inspections/{id}  { allow read, write: if isSignedIn(); }
    match /cost_entries/{id}       { allow read, write: if isSignedIn(); }
    match /site_diary/{id}         { allow read, write: if isSignedIn(); }
    match /issues/{id}             { allow read, write: if isSignedIn(); }
    match /risks/{id}              { allow read, write: if isSignedIn(); }
    match /qc_records/{id}         { allow read, write: if isSignedIn(); }
    match /approvals/{id}          { allow read, write: if isSignedIn(); }
    match /progress_updates/{id}   { allow read, write: if isSignedIn(); }
    match /notifications/{id}      { allow read, write: if isSignedIn(); }

    // ──────────────────────────────────────────────────────────
    // Default deny — anything not explicitly listed above
    // ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
